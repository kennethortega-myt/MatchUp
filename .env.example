# ── Database ──────────────────────────────────────────────────────────────────
# Local:  mysql+pymysql://root:@localhost:3306/matchup?charset=utf8mb4
# TiDB:   mysql+pymysql://user:pass@host:4000/matchup?charset=utf8mb4&ssl_verify_cert=true
DATABASE_URL=

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_SECRET_KEY=change-me

# ── Business logic ────────────────────────────────────────────────────────────
WOMAN_SHARE=0.30

# ── Photo storage ─────────────────────────────────────────────────────────────
# Use "local" for development, "r2" for production
STORAGE_BACKEND=local

# Only needed when STORAGE_BACKEND=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=matchup-photos
# Public URL of the R2 bucket (enable in Cloudflare dashboard)
R2_PUBLIC_URL=https://pub-XXXX.r2.dev

# Only needed when STORAGE_BACKEND=local
UPLOAD_DIR=uploads

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (besides localhost)
# e.g. https://matchup.vercel.app
FRONTEND_ORIGIN=
